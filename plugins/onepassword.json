{
  "name": "onepassword",
  "version": "1.0.0",
  "tools": [
    {
      "name": "ctx_op_items",
      "description": "List all items in the current 1Password vault",
      "command": "op item list"
    },
    {
      "name": "ctx_op_get",
      "description": "Get details of a specific 1Password item",
      "command": "op item get {{item}}",
      "input_schema": {
        "type": "object",
        "properties": {
          "item": {
            "type": "string",
            "description": "Item name or ID to retrieve"
          }
        },
        "required": ["item"]
      }
    },
    {
      "name": "ctx_op_vaults",
      "description": "List all available 1Password vaults",
      "command": "op vault list"
    }
  ]
}
